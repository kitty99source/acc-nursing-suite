{
  "$schema": "acc-office-config-v1",
  "officeName": "Example District Nursing — North",
  "notes": "Forkable baseline for U-26. Import via Settings → Office config. Does not include patient PHI.",
  "accInbox": {
    "inboxPath": "",
    "notes": "Leave inboxPath empty for default %USERPROFILE%\\ACC-Inbox. Set a writable path if IT blocks profile folders (e.g. H:\\ACC-Inbox). Also overridable via env ACC_INBOX_PATH or ACC_INBOX.",
    "senderAllowlist": [
      "Bec.Williams@acc.co.nz",
      "John.Bentley@acc.co.nz",
      "Becky.Tunnell@acc.co.nz",
      "nursing@acc.co.nz",
      "acc.co.nz",
      "acc.govt.nz"
    ],
    "subjectPatterns": [
      "Claim:",
      "ACCID:",
      "approv",
      "declin",
      "nur0[245]",
      "purchase order",
      "PO\\s*number",
      "ACC\\s+letter"
